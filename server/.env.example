# Gemini — get from https://aistudio.google.com/apikey (starts with AIza...)
GEMINI_API_KEY=

# Google Sheets — share your spreadsheet with the service account email
SPREADSHEET_ID=

# Option A (easiest): path to downloaded service account JSON file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# Option B: paste values from the JSON file manually
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
